<Page x:Class="HospitalApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная" Background="White">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Панель управления" FontSize="28" FontWeight="Light" Foreground="#4A5D4A"/>
            <TextBlock Text="Обзор состояния системы на сегодня" FontSize="14" Foreground="#99A399" Margin="0,5,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top" Margin="0,0,0,30">
            <Border Background="#F7F9F7" Margin="10" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="📅 Приемы сегодня" FontSize="13" Foreground="#749374" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTodayApp" Text="0" FontSize="42" FontWeight="Bold" Foreground="#4A5D4A" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#F7F9F7" Margin="10" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="👥 Всего пациентов" FontSize="13" Foreground="#749374" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalPatients" Text="0" FontSize="42" FontWeight="Bold" Foreground="#4A5D4A" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#F7F9F7" Margin="10" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="👨‍⚕️ Врачи в штате" FontSize="13" Foreground="#749374" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalDoctors" Text="0" FontSize="42" FontWeight="Bold" Foreground="#4A5D4A" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Ближайшие записи (на сегодня)" FontSize="18" Foreground="#4A5D4A" Margin="10,0,0,15" FontWeight="SemiBold"/>

            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#F0F5F0" BorderThickness="1" Margin="10,0,10,10">
                <DataGrid x:Name="dgUpcoming" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="Transparent" BorderThickness="0" RowHeight="45"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F7F9F7">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F7F9F7"/>
                            <Setter Property="Foreground" Value="#749374"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Время" Binding="{Binding AppointmentDateTime, StringFormat={}{0:HH:mm}}" Width="100"/>
                        <DataGridTextColumn Header="Пациент" Binding="{Binding Patient.LastName}" Width="*"/>
                        <DataGridTextColumn Header="Врач" Binding="{Binding Doctor.LastName}" Width="*"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>