<Window x:Class="HospitalApp.Views.AddPatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый пациент" Height="375" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#F7F9F7">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Карточка пациента" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#4A5D4A"/>
            <TextBlock Text="Полное ФИО пациента" Margin="0,5,0,2" FontWeight="Bold" Foreground="#4A5D4A"/>
            <TextBox x:Name="txtFullName" Height="35" VerticalContentAlignment="Center" Padding="5,0" 
         ToolTip="Введите Фамилию Имя Отчество через пробел"/>

            <TextBlock Text="Дата рождения" Margin="0,15,0,2"/>
            <DatePicker x:Name="dpBirthDate" Height="30"/>

            <TextBlock Text="Телефон" Margin="0,15,0,2"/>
            <TextBox x:Name="txtPhone" Height="30" VerticalContentAlignment="Center"/>

            <UniformGrid Columns="2" Margin="0,30,0,0">
                <Button Content="СОХРАНИТЬ" Click="btnSave_Click" Height="40" Background="#749374" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="ОТМЕНА" Click="btnCancel_Click" Height="40" Background="#E0E8E0" Margin="5,0,0,0"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>