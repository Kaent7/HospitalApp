<Page x:Class="HospitalApp.Pages.DoctorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Врачи" Background="White">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Штат сотрудников" FontSize="26" Foreground="#4A5D4A" FontWeight="Light"/>
            <TextBlock Text="Управление медицинским персоналом" FontSize="12" Foreground="#99A399"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#F0F5F0" BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="dgDoctors" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" BorderThickness="0" RowHeight="50"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F7F9F7">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F7F9F7"/>
                        <Setter Property="Foreground" Value="#749374"/>
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО Врача" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Специализация" Binding="{Binding Specializations.Title}" Width="200"/>
                    <DataGridTextColumn Header="Кабинет" Binding="{Binding Cabinets.RoomNumber}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button x:Name="btnAddDoctor" Grid.Row="2" Content="Добавить нового врача" 
                HorizontalAlignment="Right" Margin="0,20,0,0" Width="220" Height="45"
                Background="#749374" Foreground="White" BorderThickness="0"
                FontSize="14" FontWeight="SemiBold" Visibility="Collapsed"
                Click="btnAddDoctor_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Page>