<Page x:Class="HospitalApp.Pages.PatientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пациенты" Background="White">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Реестр пациентов" FontSize="26" 
                   Foreground="#4A5D4A" Margin="0,0,0, 20" FontWeight="Light"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="ПОИСК ПО ФАМИЛИИ" FontSize="10" FontWeight="Bold" 
                       Foreground="#99A399" Margin="5,0,0,5"/>
            <TextBox x:Name="txtSearch" Width="350" Height="36" HorizontalAlignment="Left"
                     VerticalContentAlignment="Center" Padding="10,0"
                     BorderBrush="#E0E8E0" TextChanged="txtSearch_TextChanged"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#F0F5F0" BorderThickness="1" CornerRadius="4">
            <DataGrid x:Name="dgPatients" AutoGenerateColumns="False" 
                      IsReadOnly="True" Background="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F7F9F7"
                      RowHeight="45">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding DateOfBirth, StringFormat={}{0:dd.MM.yyyy}}" Width="150"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Добавить пациента" Width="200" Height="42" 
                    Background="#749374" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold" Click="btnAdd_Click">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Page>