<Window x:Class="HospitalApp.Views.AddAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая запись" Height="450" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#F7F9F7"
        FontFamily="Segoe UI" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Оформление приема" FontSize="20" Foreground="#4A5D4A" Margin="0,0,0,20"/>

            <TextBlock Text="Дата и время" FontSize="12" FontWeight="Bold" Foreground="#99A399" Margin="0,0,0,5"/>
            <DatePicker x:Name="dpDate" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="Пациент" FontSize="12" FontWeight="Bold" Foreground="#99A399" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbPatients" Height="35" Margin="0,0,0,15" DisplayMemberPath="FullName"/>

            <TextBlock Text="Врач" FontSize="12" FontWeight="Bold" Foreground="#99A399" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbDoctors" Height="35" Margin="0,0,0,15" DisplayMemberPath="FullName"/>

            <TextBlock Text="Статус" FontSize="12" FontWeight="Bold" Foreground="#99A399" Margin="0,0,0,5"/>
            <TextBox x:Name="txtStatus" Text="Запланировано" Height="35" Margin="0,0,0,30" VerticalContentAlignment="Center" Padding="5,0"/>

            <UniformGrid Columns="2">
                <Button Content="Отмена" Click="Cancel_Click" Margin="0,0,5,0" Height="40" Background="Transparent" BorderBrush="#E0E8E0"/>
                <Button Content="Сохранить" Click="Save_Click" Height="40" Background="#749374" Foreground="White" BorderThickness="0"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>