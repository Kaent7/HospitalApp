<Window x:Class="HospitalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hospital System v1.0" Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen" Background="#F7F9F7">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE5DD"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5E755E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#4A5D4A" CornerRadius="0,20,20,0">
            <StackPanel Margin="20,40,20,20">
                <TextBlock Text="Tranquil Hospital" Foreground="White" FontSize="22" 
               FontWeight="Bold" Margin="0,0,0,40" HorizontalAlignment="Center"/>

                <Button x:Name="btnHome" Content="🏠 Главная" Style="{DynamicResource NavButtonStyle}" 
            Click="Nav_Click" Cursor="Hand"/>

                <Button x:Name="btnAppointments" Content="📅 Журнал записей" Style="{DynamicResource NavButtonStyle}" 
            Click="Nav_Click" Cursor="Hand"/>

                <Button x:Name="btnPatients" Content="👥 Пациенты" Style="{DynamicResource NavButtonStyle}" 
            Click="Nav_Click" Cursor="Hand"/>

                <Button x:Name="btnDoctors" Content="👨‍⚕️ Врачи" Style="{DynamicResource NavButtonStyle}" 
            Click="Nav_Click" Cursor="Hand"/>
                
                <Separator Background="#637A63" Margin="0,20"/>

                <Button x:Name="btnExit" Content="🚪 Выход" Style="{DynamicResource NavButtonStyle}" 
            Click="Exit_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>
       
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>