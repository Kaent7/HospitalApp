<Window x:Class="HospitalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hospital System v1.0" Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen" Background="#F7F9F7">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#4A5D4A" CornerRadius="0,20,20,0">
            <StackPanel Margin="20,40,20,20">
                <TextBlock Text="Tranquil Hospital" Foreground="White" FontSize="22" 
                           FontWeight="Bold" Margin="0,0,0,40" HorizontalAlignment="Center"/>

                <Button x:Name="btnHome" Content="🏠 Главная" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                <Button x:Name="btnAppointments" Content="📅 Журнал записей" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                <Button x:Name="btnPatients" Content="👥 Пациенты" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>

                <Separator Background="#637A63" Margin="0,20"/>
                <TextBlock x:Name="txtUserRole" Foreground="#DDE5DD" FontSize="12" 
           HorizontalAlignment="Center" Margin="0,-35,0,40" Opacity="0.7"/>
                <Button x:Name="btnExit" Content="🚪 Выход" Style="{StaticResource NavButtonStyle}" Click="Exit_Click"/>
            </StackPanel>
        </Border>
       
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>